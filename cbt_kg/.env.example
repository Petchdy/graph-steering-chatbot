# Graph backend: "memory" (default) or "neo4j"
GRAPH_BACKEND=memory
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Extractor: "local" (default — V4_flat TurnPipeline via Ollama) or "stub" (offline)
EXTRACTOR=local
OLLAMA_MODEL=qwen3.5-nothink
OLLAMA_HOST=http://localhost:11434

# Generator: "local" (default), "echo" (offline tests), "openrouter", or "steered"
GENERATOR=local
LOCAL_LLM_MODEL=qwen3.5-nothink
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# NOTE: the /v1 suffix is accepted but stripped — native /api/chat is always used.

# Steering overlay (GENERATOR=steered): reply is steered by the local steering service (see
# steering/NOTES.md); CBT technique/phase still come from Ollama. Manual strategy button in the UI.
STEER_URL=http://localhost:8100
STEER_DEFAULT_STRATEGY=none

# Extraction pipeline
EXTRACTION_TIMEOUT=8        # if extraction finishes within this window, the
                            # graph is updated before the reply is sent.
CONSOLIDATE_EVERY=6         # Tier B (session-level/reinforces/reframe) fires
                            # every Nth client turn as a background task.
EXTRACT_FAST=0              # set 1 to collapse Stage 2.5 properties into Stage 1
                            # for fewer LLM calls (lower fidelity).
EXTRACT_LANGUAGE=English    # transcript language hint (the V4_flat prompts read it)

# OpenRouter (optional alternative to local Ollama)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
