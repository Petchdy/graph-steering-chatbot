# Graph backend: "memory" (default, no DB) or "neo4j"
GRAPH_BACKEND=memory
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Extractor: "local" (default, Ollama) or "stub" (offline regex, tests only)
EXTRACTOR=local
OLLAMA_MODEL=qwen3.5-nothink
OLLAMA_HOST=http://localhost:11434

# Generator: "local" (default, Ollama) or "echo" (offline stub, tests only) or "openrouter"
GENERATOR=local
LOCAL_LLM_MODEL=qwen3.5-nothink
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# NOTE: /v1 suffix is accepted but stripped — native /api/chat is always used

# Extraction pipeline timeout in seconds.
# If extraction finishes within this window, graph is updated before reply (Option 1).
# If not, extraction continues in background after reply is sent (Option 2).
EXTRACTION_TIMEOUT=8

# OpenRouter (optional alternative to local Ollama)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
